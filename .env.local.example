# ChorusSync Environment Variables
# Copy to .env.local and fill in your values

# Google AI — used for Gemma 3 27B (primary) + Gemini 2.5 Flash (fallback)
# Get your key from https://aistudio.google.com/apikey
# Free tier: Gemma 3 27B = 14,400 RPD, Gemini 2.5 Flash = 20 RPD
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Supabase (optional — for cross-device sync, not required for local development)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
